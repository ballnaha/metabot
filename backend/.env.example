# ============================================================
# MetaBot configuration — copy to .env and fill in your values
# ============================================================

# ---- MT5 account ----
# Leave login/password/server empty to attach to an ALREADY-RUNNING
# MT5 terminal that you logged into manually.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Optional full path to terminal64.exe (only if not auto-detected)
MT5_PATH=
# Deprecated compatibility setting; MT5 Python timestamps are already UTC.
MT5_SERVER_UTC_OFFSET=0

# ---- AI providers (advice engine) ----
# Deepseek. Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Gemini (Google AI Studio). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Which providers to ask: comma list of deepseek,gemini
AI_PROVIDERS=deepseek,gemini
# USE_AI=true  -> strategy signal must also be confirmed by the AI (extra filter)
# USE_AI=false -> strategy decides on its own, no AI calls
USE_AI=true

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# Only this chat id may control the bot (your own user id)
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ---- Trading parameters ----
# Symbols the bot may analyse / trade. Broker suffixes are resolved automatically,
# including Exness Standard "m" and Standard Cent "c" (XAUUSD -> XAUUSDc).
SYMBOLS=USDJPY,XAUUSD
# Default timeframe for analysis: M1,M5,M15,M30,H1,H4,D1
DEFAULT_TIMEFRAME=H1

# Crypto (disabled until a broker-specific backtest shows positive net expectancy)
BOT_ENABLED=false
CRYPTO_TIMEFRAME=H1
CRYPTO_STRATEGY=adaptive_trend
CRYPTO_ATR_SL_MULT=1.8
CRYPTO_RR=2.5
# Floor on SL distance as a fraction of price (e.g. 0.018 = 1.8%). Prevents a
# shrunk ATR from making the stop so tight that spread dominates it. 0 = off.
CRYPTO_MIN_SL_PCT=0.0
CRYPTO_BREAKOUT_ENABLED=false
# Force-close crypto before overnight costs accumulate. 0 = off.
CRYPTO_MAX_HOLD_HOURS=0.0

# Gold
GOLD_BOT_ENABLED=true
GOLD_TIMEFRAME=M30
GOLD_STRATEGY=squeeze_breakout
GOLD_MIN_SL_PCT=0.0
GOLD_MAGIC=556688
MAX_GOLD_OPEN_TRADES=1

# Forex
FOREX_BOT_ENABLED=true
FOREX_TIMEFRAME=H1
FOREX_STRATEGY=squeeze_breakout
FOREX_RISK_PER_TRADE=0.01
FOREX_MAX_LOT=1.0
FOREX_ATR_SL_MULT=1.5
FOREX_MIN_SL_PCT=0.0
FOREX_RR=2.0
FOREX_USE_AI=false
FOREX_AUTO_TRADE_INTERVAL=300
FOREX_MAX_HOLD_HOURS=4
FOREX_MAGIC=556699
MAX_FOREX_OPEN_TRADES=1

# Stocks (disabled until each symbol has a sufficiently large backtest sample)
STOCK_BOT_ENABLED=false
STOCK_TIMEFRAME=M30
STOCK_STRATEGY=stock_pullback
STOCK_RISK_PER_TRADE=0.005
STOCK_MAX_LOT=5.0
STOCK_ATR_SL_MULT=2.0
STOCK_MIN_SL_PCT=0.0
STOCK_RR=3.0
STOCK_USE_AI=false
STOCK_AUTO_TRADE_INTERVAL=900
STOCK_MAGIC=556700
MAX_STOCK_OPEN_TRADES=4

# Generic settings used by gold and crypto
STRATEGY=trend
# Risk per trade as fraction of account balance (0.01 = 1%)
RISK_PER_TRADE=0.005
# Hard cap on lot size per order
MAX_LOT=1.0
# Magic number to tag this bot's orders
MAGIC=556677
# ATR multiplier for stop loss if AI does not supply one
ATR_SL_MULT=1.5
# Reward:risk for take profit if AI does not supply one
DEFAULT_RR=2.0
POSITION_SIZING_MODE=risk_pct
# Used only when POSITION_SIZING_MODE=equal_slots.
STAKE_AMOUNT=0.0
MAX_OPEN_TRADES=5
MAX_CRYPTO_OPEN_TRADES=3
AUTO_TRADE_INTERVAL=30
# Reject a quote when spread consumes more than this fraction of SL distance.
MAX_SPREAD_TO_SL=0.25
# Crypto CFDs commonly have wider spreads; 0.50 means at most half of SL distance.
CRYPTO_MAX_SPREAD_TO_SL=0.50
# Reject a closed-candle signal if current bid has already moved this many R.
MAX_ENTRY_DRIFT_TO_SL=0.75
MAX_SPREAD_POINTS=0
BREAKEVEN_R=1.0
TRAILING_STOP_R=1.5
# Safety circuit breakers (0 disables them).
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3
# Skip a trade when the broker's minimum lot forces a position worth more than
# this multiple of the intended stake/risk (e.g. BTC min 0.01 lot ≈ $600 vs a
# $100 stake = 6×). 0 disables the guard (always trade the min lot). 3 is a
# sane starting point: tolerate up to 3× over-exposure, skip beyond that.
MIN_LOT_STAKE_MULTIPLE=0
# Second risk layer: cap one position's notional at this multiple of equity,
# after risk sizing. Stops a tight SL from sizing a huge lot (small $ risk but
# big gap exposure). e.g. 2.0 = a position may be at most 2× the account value.
# 0 disables it. Final lot = min(risk_lot, notional_cap_lot).
MAX_NOTIONAL_TO_EQUITY=0


# ---- API server ----
API_HOST=127.0.0.1
API_PORT=8383
# Shared secret the frontend / clients must send as X-API-Key
API_KEY=change-me-please
# Browser origins allowed to call the API (CORS), comma-separated.
# Defaults to the local dashboard. Add your deployed dashboard URL here.
# Use "*" only if you understand the risk (any site could call the API).
CORS_ORIGINS=http://localhost:4016,http://127.0.0.1:4016

# ---- Backtest ----
# Round-turn commission ($/lot, entry + exit) your broker charges, used by the
# backtester's cost model. Swap is read from each symbol automatically; this is
# the one cost MT5 can't report per-symbol. 0 = ignore. Raw-spread accounts
# often charge ~7 (≈ $3.5/side). Check your account's contract specs.
BACKTEST_COMMISSION_PER_LOT=0.0
# Optional per-symbol strategy map produced by `run_backtest.py --optimize`.
# When set, the bot trades each listed symbol with its best backtested strategy;
# unlisted symbols fall back to the group strategy. Leave empty to disable.
SYMBOL_STRATEGIES_FILE=
